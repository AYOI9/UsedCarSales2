                    xmlns:vm="clr-namespace:UsedCarsClient.ViewModels"
                    xmlns:view="clr-namespace:UsedCarsClient.Views">
    <DataTemplate DataType="{x:Type vm:HomeViewModel}">
        <view:HomeView/>
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:ClientsViewModel}">
        <view:ClientsView/>
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:ContractsViewModel}">
        <view:ContractsView/>
    </DataTemplate>
</ResourceDictionary>
