<UserControl x:Class="UsedCarsClient.Views.ContractsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0 0 0 5">
            <Button Margin="0 0 5 0" Command="{Binding RefreshCommand}">
                <StackPanel Orientation="Horizontal">
                    <Image Source="/Assets/table.png" Width="16" Height="16" Margin="0,0,5,0"/>
                    <TextBlock Text="Обновить"/>
                </StackPanel>
            </Button>
            <Button Margin="0 0 5 0" Command="{Binding AddCommand}">
                <StackPanel Orientation="Horizontal">
                    <Image Source="/Assets/add.png" Width="16" Height="16" Margin="0,0,5,0"/>
                    <TextBlock Text="Добавить"/>
                </StackPanel>
            </Button>
            <Button Margin="0 0 5 0" Command="{Binding EditCommand}">
                <StackPanel Orientation="Horizontal">
                    <Image Source="/Assets/book-open.png" Width="16" Height="16" Margin="0,0,5,0"/>
                    <TextBlock Text="Изменить"/>
                </StackPanel>
            </Button>
            <Button Command="{Binding DeleteCommand}">
                <StackPanel Orientation="Horizontal">
                    <Image Source="/Assets/Del.png" Width="16" Height="16" Margin="0,0,5,0"/>
                    <TextBlock Text="Удалить"/>
                </StackPanel>
            </Button>
        </StackPanel>

        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding Contracts}"
                  SelectedItem="{Binding SelectedContract}"
                  AutoGenerateColumns="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="№" Binding="{Binding ContractId}"/>
                <DataGridTextColumn Header="Клиент" Binding="{Binding ClientName}"/>
                <DataGridTextColumn Header="Дата договора" Binding="{Binding ContractDate, StringFormat=d}"/>
                <DataGridTextColumn Header="Марка" Binding="{Binding CarMake}"/>
                <DataGridTextColumn Header="Модель" Binding="{Binding CarModel}"/>
                <DataGridTextColumn Header="Дата выпуска" Binding="{Binding ProductionDate, StringFormat=d}"/>
                <DataGridTextColumn Header="Пробег" Binding="{Binding Mileage}"/>
                <DataGridTextColumn Header="Дата продажи" Binding="{Binding SaleDate, StringFormat=d}"/>
                <DataGridTextColumn Header="Цена" Binding="{Binding SalePrice}"/>
                <DataGridTextColumn Header="Комиссия" Binding="{Binding Commission}"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
