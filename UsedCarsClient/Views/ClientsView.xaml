<UserControl x:Class="UsedCarsClient.Views.ClientsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0 0 0 5">
            <Button Margin="0 0 5 0" Command="{Binding RefreshCommand}">
                <StackPanel Orientation="Horizontal">
                    <Image Source="/Assets/table.png" Width="16" Height="16" Margin="0,0,5,0"/>
                    <TextBlock Text="Обновить"/>
                </StackPanel>
            </Button>
            <Button Margin="0 0 5 0" Command="{Binding AddCommand}">
                <StackPanel Orientation="Horizontal">
                    <Image Source="/Assets/add.png" Width="16" Height="16" Margin="0,0,5,0"/>
                    <TextBlock Text="Добавить"/>
                </StackPanel>
            </Button>
            <Button Margin="0 0 5 0" Command="{Binding EditCommand}">
                <StackPanel Orientation="Horizontal">
                    <Image Source="/Assets/book-open.png" Width="16" Height="16" Margin="0,0,5,0"/>
                    <TextBlock Text="Изменить"/>
                </StackPanel>
            </Button>
            <Button Command="{Binding DeleteCommand}">
                <StackPanel Orientation="Horizontal">
                    <Image Source="/Assets/Del.png" Width="16" Height="16" Margin="0,0,5,0"/>
                    <TextBlock Text="Удалить"/>
                </StackPanel>
            </Button>
        </StackPanel>
        <DataGrid Grid.Row="1" ItemsSource="{Binding Clients}" SelectedItem="{Binding SelectedClient}"
                  AutoGenerateColumns="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Фамилия" Binding="{Binding LastName}"/>
                <DataGridTextColumn Header="Имя" Binding="{Binding FirstName}"/>
                <DataGridTextColumn Header="Отчество" Binding="{Binding MiddleName}"/>
                <DataGridTextColumn Header="Город" Binding="{Binding City}"/>
                <DataGridTextColumn Header="Адрес" Binding="{Binding Address}"/>
                <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
