<Window x:Class="UsedCarsClient.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:UsedCarsClient.ViewModels"
        Title="Продажа подержанных автомобилей" Height="450" Width="800">
    <Grid>
        <DockPanel>
            <StackPanel DockPanel.Dock="Left" Width="180" Background="#eee">
                <Button Margin="5" Padding="5" Command="{Binding HomeCommand}">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="/Assets/img_home.png" Width="16" Height="16" Margin="0,0,5,0"/>
                        <TextBlock Text="Главная"/>
                    </StackPanel>
                </Button>
                <Button Margin="5" Padding="5" Command="{Binding ClientsCommand}">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="/Assets/img_customer.png" Width="16" Height="16" Margin="0,0,5,0"/>
                        <TextBlock Text="Клиенты"/>
                    </StackPanel>
                </Button>
                <Button Margin="5" Padding="5" Command="{Binding ContractsCommand}">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="/Assets/table.png" Width="16" Height="16" Margin="0,0,5,0"/>
                        <TextBlock Text="Контракты"/>
                    </StackPanel>
                </Button>
            </StackPanel>
            <ContentControl Content="{Binding CurrentView}" Margin="10"/>
        </DockPanel>
    </Grid>
</Window>
